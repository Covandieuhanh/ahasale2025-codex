  <!--rewrite url-->
  <system.webServer>
    <rewrite>
      <rules>
        <!-- Các quy tắc rewrite khác -->
        <!-- Quy tắc rewrite từ URL gốc sang URL đã rewrite -->
        <rule name="Rewrite to URL Page" stopProcessing="true">
          <match url="^test/([^/]+)/([^/]+)\.html" />
          <action type="Rewrite" url="/url.aspx?id={R:1}&amp;name={R:2}" />
        </rule>
        <rule name="baotri" stopProcessing="true">
          <match url="^bao-tri$" />
          <action type="Rewrite" url="/home/bao-tri.aspx" />
        </rule>
        <rule name="dangnhap" stopProcessing="true">
          <match url="^dang-nhap$" />
          <action type="Rewrite" url="/home/login.aspx" />
        </rule>
        <!-- Quy tắc rewrite cho trang danh sách bài viết -->
        <rule name="Rewrite to Danh Sach Bai Viet Page" stopProcessing="true">
          <match url="^([^/]+)-(\d+)$" />
          <action type="Rewrite" url="/home/page/ds-bai-viet.aspx?idmn={R:2}" />
        </rule>
        <!-- Quy tắc rewrite cho trang chi tiết bài viết -->
        <rule name="Rewrite to Chi Tiet Bai Viet Page" stopProcessing="true">
          <match url="^([^/]+)-(\d+)\.html$" />
          <action type="Rewrite" url="/home/page/chi-tiet-bai-viet.aspx?idbv={R:2}" />
        </rule>
        <!-- Quy tắc rewrite từ /home/default.aspx?user='taikhoan' sang /taikhoan.info -->
        <rule name="Rewrite to Dynamic User Info Page" stopProcessing="true">
          <match url="^([^/]+)\.info$" />
          <action type="Rewrite" url="/home/default.aspx?user={R:1}" />
        </rule>
      </rules>
    </rewrite>
    <security>
      <requestFiltering>
        <requestLimits maxAllowedContentLength="314572800" />
        <!-- 300MB -->
      </requestFiltering>
    </security>
  </system.webServer>
</configuration>
