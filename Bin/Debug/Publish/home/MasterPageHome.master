    <asp:ContentPlaceHolder ID="head" runat="server"></asp:ContentPlaceHolder>
    <style>
        .bg-yellow {
            background-color: #f0b90e !important
        }

        .fg-yellow {
            color: #f0b90e !important
        }

        .fg-yellow-hover:hover {
            color: #f0b90e !important
        }

        .fg-ahasale {
            color: #eaecef; /*trắng*/
        }

        .fg-ahasale1 {
            color: #848e9c; /*xám xanh*/
        }

        .bg-ahasale1 {
            background-color: #1e2329; /*nền tối nhạt*/
        }

        .bg-ahasale {
            background-color: #181a20; /*nền tối đậm*/
        }
        .user-block {
            right: -114px !important;
        }

        .footer-section {
            padding: 24px 0;
            font-size: 14px;
        }

        .footer-section p {
            font-weight: bold;
            margin-bottom: 10px;
            color: white;
            text-align: left;
        }

        .footer-section ul {
            list-style: none;
            padding-left: 0;
            margin: 0;
        }

        .footer-section li {
            margin-bottom: 10px;
            text-align: left;
        }

        .footer-section a {
            text-decoration: none;
            color: white !important;
            transition: color 0.3s ease;
        }

        .footer-section a:hover {
            color: #007bff;
            text-decoration: underline;
        }

        .footer-section img.store-icon {
            width: 120px;
            margin-bottom: 8px;
        }

        .footer-section .qr-app {
            width: 87px;
            height: 87px;
            border: 1px solid #ccc;
            margin-right: 15px;
        }

        .footer-section .social-icons img {
            width: 32px;
            height: 32px;
            margin-right: 10px;
            transition: transform 0.3s ease;
        }

        .footer-section .social-icons img:hover {
            transform: scale(1.1);
        }

        @media (max-width: 768px) {
            .footer-section .row {
                flex-direction: column;
            }

            .footer-section .cell-lg-3 {
                margin: 0 0 20px 20px;
            }
        }
    </style>
</head>
<body style="background-color: #181a20">
    <form id="form1" runat="server">
        <asp:ScriptManager ID="ScriptManager1" runat="server" EnableScriptGlobalization="True"></asp:ScriptManager>

        <uc1:menutophomeuc runat="server" ID="menutophomeuc" />

        <div style="margin-top: 52px">
            <asp:ContentPlaceHolder ID="main" runat="server"></asp:ContentPlaceHolder>
        </div>


        <div class="pt-3 pb-3 text-center-lg text-left mt-3" style="background-color: #1e2329; color: #eaecef">
            
            <div class="footer-section container row">
                <div class="cell-lg-3">
                    <p>TẢI ỨNG DỤNG AHASALE</p>
                    <div class="d-flex">
                        <div>
                            <ul>
                                <li>
                                    <img alt="App Store" src="/uploads/images/ios.svg" class="store-icon">
                                </li>
                                <li>
                                    <img alt="Google Play" src="/uploads/images/android.svg" class="store-icon">
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>

                <div class="cell-lg-3">
                    <p>HỖ TRỢ KHÁCH HÀNG</p>
                    <ul>
                        <li>Trung tâm trợ giúp</li>
                        <li>An toàn mua bán</li>
                        <li>Liên hệ hỗ trợ</li>
                    </ul>
                </div>

                <div class="cell-lg-3">
                    <p>VỀ AHASALE</p>
                    <ul>
                        <li>Giới thiệu</li>
                        <li>Quy chế hoạt động sàn</li>
                        <li>Chính sách bảo mật</li>
                        <li>Giải quyết tranh chấp</li>
                        <li>Tuyển dụng</li>
                        <li>Truyền thông</li>
                        <li>Blog</li>
                    </ul>
                </div>

                <div class="cell-lg-3">
                    <p>LIÊN KẾT</p>
                    <ul class="social-icons d-flex">
                        <li>
                            <img alt="Facebook" src="https://static.chotot.com/storage/default/facebook.svg">
                        </li>
                        <li>
                            <img alt="Youtube" src="https://static.chotot.com/storage/default/youtube.svg">
                        </li>
                        <li>
                            <img alt="LinkedIn" src="https://static.chotot.com/storage/default/linkedin.svg">
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <script src="/Metro-UI-CSS-master/js/metro.min.js"></script>
        <script src="/js/bcorn.js"></script>
        <asp:ContentPlaceHolder ID="foot" runat="server"></asp:ContentPlaceHolder>
        <%=ViewState["thongbao_home"] %>
    </form>
</body>
</html>
