# Data provider:
# - rpc: balance mode (khuyen nghi, khong can goi API plan, khong dung getLogs)
# - rpc_logs: log scan mode (chi de debug khi can)
# - etherscan: can API key V2
CHAIN_DATA_PROVIDER=rpc
BSC_RPC_URL=https://bsc-dataseed2.binance.org
RPC_BLOCK_STEP=20
RPC_MIN_BLOCK_STEP=1
RPC_REQUEST_DELAY_MS=300
INITIAL_LOOKBACK_BLOCKS=200
