# Web endpoint bridge
USDT_BRIDGE_API_URL=http://localhost:8081/admin/api/usdt-bridge-credit.aspx
USDT_BRIDGE_API_KEY=CHANGE_ME_STRONG_KEY
USDT_BRIDGE_SIGNING_SECRET=CHANGE_ME_STRONG_SIGNING_SECRET

# Wallet theo doi (BSC BEP20)
BSC_DEPOSIT_ADDRESS=0xCHANGE_ME_BSC_ADDRESS
# Token doi ung diem A (chi can thay contract nay khi doi token)
BSC_TOKEN_CONTRACT=0x55d398326f99059ff775485246999027b3197955
# Legacy fallback:
BSC_USDT_CONTRACT=0x55d398326f99059ff775485246999027b3197955
# Data provider:
# - rpc: balance mode (khuyen nghi, khong can goi API plan, khong dung getLogs)
# - rpc_logs: log scan mode (chi de debug khi can)
# - etherscan: can API key V2
CHAIN_DATA_PROVIDER=rpc
BSC_RPC_URL=https://bsc-dataseed.binance.org
RPC_BLOCK_STEP=200
RPC_MIN_BLOCK_STEP=1
RPC_REQUEST_DELAY_MS=120
INITIAL_LOOKBACK_BLOCKS=5000
# -1 = auto goi decimals() tu contract
TOKEN_DECIMALS=-1
BSCSCAN_API_URL=https://api.etherscan.io/v2/api
BSCSCAN_API_KEY=CHANGE_ME_ETHERSCAN_V2_API_KEY
BSC_CHAIN_ID=56

# Policy
MIN_CONFIRMATIONS=20
POLL_SECONDS=30
BATCH_SIZE=50
HTTP_TIMEOUT=20

# Local state
STATE_FILE=./scripts/usdt_bridge_state.json
