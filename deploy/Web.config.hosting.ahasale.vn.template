  <system.webServer>
    <rewrite>
      <rules>
        <rule name="Rewrite to URL Page" stopProcessing="true">
          <match url="^test/([^/]+)/([^/]+)\.html" />
          <action type="Rewrite" url="/url.aspx?id={R:1}&amp;name={R:2}" />
        </rule>
        <rule name="baotri" stopProcessing="true">
          <match url="^bao-tri$" />
          <action type="Rewrite" url="/home/bao-tri.aspx" />
        </rule>
        <rule name="dangnhap" stopProcessing="true">
          <match url="^dang-nhap$" />
