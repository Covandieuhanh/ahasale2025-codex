# Public endpoint on hosting (do not use localhost here)
USDT_BRIDGE_API_URL=https://__SITE_DOMAIN__/admin/api/usdt-bridge-credit.aspx
USDT_BRIDGE_API_KEY=CHANGE_ME_BRIDGE_API_KEY
USDT_BRIDGE_SIGNING_SECRET=CHANGE_ME_BRIDGE_SIGNING_SECRET

# Wallet/token to track on BSC
BSC_DEPOSIT_ADDRESS=__DEPOSIT_ADDRESS__
BSC_TOKEN_CONTRACT=__TOKEN_CONTRACT__

# Provider: rpc_balance is stable and does not require Etherscan paid plan
CHAIN_DATA_PROVIDER=rpc_balance
BSC_RPC_URL=https://bsc-dataseed.binance.org

# Policy
MIN_CONFIRMATIONS=20
POLL_SECONDS=30
HTTP_TIMEOUT=20

# Optional tuning
RPC_BLOCK_STEP=200
RPC_MIN_BLOCK_STEP=1
RPC_REQUEST_DELAY_MS=120
INITIAL_LOOKBACK_BLOCKS=5000
TOKEN_DECIMALS=-1

# Optional Etherscan mode
BSCSCAN_API_URL=https://api.etherscan.io/v2/api
BSCSCAN_API_KEY=
BSC_CHAIN_ID=56

# Local state (on the machine that runs watcher)
STATE_FILE=./scripts/usdt_bridge_state.json
