<%@ Master Language="C#" AutoEventWireup="true" CodeFile="mp-webcon.master.cs" Inherits="webcon_mp_webcon" %>


<%@ Register Src="~/gianhang/uc/bottom_uc.ascx" TagPrefix="uc1" TagName="bottom_uc" %>

<%@ Register Src="~/gianhang/webcon/uc/dangky_tk_webcon_uc.ascx" TagPrefix="uc1" TagName="dangky_tk_webcon_uc" %>
<%@ Register Src="~/gianhang/webcon/uc/dangnhap_webcon_uc.ascx" TagPrefix="uc1" TagName="dangnhap_webcon_uc" %>
<%@ Register Src="~/gianhang/webcon/uc/menutop_webcon_uc.ascx" TagPrefix="uc1" TagName="menutop_webcon_uc" %>
<%@ Register Src="~/gianhang/webcon/uc/footer_webcon_uc.ascx" TagPrefix="uc1" TagName="footer_webcon_uc" %>








<!DOCTYPE html>

<html>
<head runat="server">

    <meta http-equiv="content-language" content="vi" />
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, user-scalable=yes" />
    <meta name="robots" content="noodp,index,follow" />
    <meta name="revisit-after" content="1 days" />
    <meta name="google" content="nositelinkssearchbox" />
    <link href="/Metro-UI-CSS-master/tests/metro/css/metro-all.min.css" rel="stylesheet" />
    <link href="/css/fix-metro.css" rel="stylesheet" />
    <link href="/css/bcorn-with-metro.css" rel="stylesheet" />
    <link href="/css/home.css" rel="stylesheet" />
    <asp:PlaceHolder runat="server">
        <%=meta %>
    </asp:PlaceHolder>
    <%=nhungma_head %>
    <asp:ContentPlaceHolder ID="head" runat="server"></asp:ContentPlaceHolder>
</head>
<body>
    <%=nhungma_body1 %>
    <form id="form1" runat="server">
        
        <asp:ScriptManager ID="ScriptManager1" runat="server" EnableScriptGlobalization="True"></asp:ScriptManager>

        <% if (Session["user_home_webcon"].ToString() == "")
            { %>
        <uc1:dangky_tk_webcon_uc runat="server" ID="dangky_tk_webcon_uc" />
        <uc1:dangnhap_webcon_uc runat="server" ID="dangnhap_webcon_uc" />
        <%} %>
       
        <asp:UpdatePanel ID="UpdatePanel1" runat="server" UpdateMode="Conditional">
            <ContentTemplate>
            </ContentTemplate>
            <Triggers>
                <asp:AsyncPostBackTrigger ControlID="Timer1" EventName="Tick" />
            </Triggers>
        </asp:UpdatePanel>
        <asp:Timer ID="Timer1" runat="server" OnTick="Timer1_Tick" Interval="4000"></asp:Timer>
        <asp:UpdateProgress ID="UpdateProgress1" runat="server" AssociatedUpdatePanelID="UpdatePanel1">
            <ProgressTemplate>
                <div class="bg-dark fixed-top h-100 w-100" style="opacity: 0.9; z-index: 99999!important">
                    <div style="padding-top: 45vh;">
                        <div class="mx-auto color-style activity-atom" data-role="activity" data-type="atom" data-style="color" data-role-activity="true"><span class="electron"></span><span class="electron"></span><span class="electron"></span></div>
                    </div>
                </div>
            </ProgressTemplate>
        </asp:UpdateProgress>

        <uc1:menutop_webcon_uc runat="server" id="menutop_webcon_uc" />

        <div style="margin-top: 52px">
            <asp:ContentPlaceHolder ID="main" runat="server"></asp:ContentPlaceHolder>
        </div>
        <uc1:footer_webcon_uc runat="server" ID="footer_webcon_uc" />
        <uc1:bottom_uc runat="server" ID="bottom_uc" />
    </form>
    <script src="/Metro-UI-CSS-master/tests/metro/js/metro.min.js"></script>
    <script src="/js/bcorn.js"></script>
    <asp:ContentPlaceHolder ID="foot" runat="server"></asp:ContentPlaceHolder>
    <%=nhungma_body2 %>
    <%=notifi %>
</body>
</html>
