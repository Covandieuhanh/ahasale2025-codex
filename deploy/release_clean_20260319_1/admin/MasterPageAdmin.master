        <script src="/Metro-UI-CSS-master/js/metro.min.js"></script>
        <script src="/js/bcorn.js"></script>
        <script src="/js/aha-ui-refresh.js?v=2026-03-07.3"></script>
        <script>
            window.ahaAdminCharms = function (action) {
                try {
                    if (!window.Metro || typeof Metro.getPlugin !== "function") {
                        return true;
                    }
                    var charms = Metro.getPlugin("#thongbao-charms", "charms");
                    if (!charms) {
                        return true;
                    }
                    if (action === "toggle" && typeof charms.toggle === "function") {
                        charms.toggle();
                    } else if (action === "open" && typeof charms.open === "function") {
                        charms.open();
                    } else if (typeof charms.close === "function") {
                        charms.close();
                    }
                } catch (err) { }
                return true;
            };
        </script>
        <script>
            (function () {
                function revealAdminAvatar() {
                    var shell = document.getElementById("admin-avatar-shell");
                    if (!shell) return;
                    shell.style.visibility = "visible";
                    shell.style.opacity = "1";
                }

                function bindAdminAvatarDropdown() {
                    var shell = document.getElementById("admin-avatar-shell");
                    var toggle = document.getElementById("admin-avatar-toggle");
                    var dropdown = document.getElementById("admin-avatar-dropdown");
                    if (!shell || !toggle || !dropdown) return;

                    if (toggle.getAttribute("data-avatar-bound") === "1") return;
                    toggle.setAttribute("data-avatar-bound", "1");

                    function closeDropdown() {
                        shell.classList.remove("open");
                        toggle.setAttribute("aria-expanded", "false");
                    }

                    function openDropdown() {
                        shell.classList.add("open");
                        toggle.setAttribute("aria-expanded", "true");
                    }

                    toggle.addEventListener("click", function (event) {
                        event.preventDefault();
                        event.stopPropagation();
                        if (shell.classList.contains("open")) {
                            closeDropdown();
                        } else {
                            openDropdown();
                        }
                    });

                    dropdown.addEventListener("click", function (event) {
                        event.stopPropagation();
                    });

                    if (!window.__ahaAdminAvatarDocBound) {
                        document.addEventListener("click", function (event) {
                            var currentShell = document.getElementById("admin-avatar-shell");
                            var currentToggle = document.getElementById("admin-avatar-toggle");
                            if (!currentShell || !currentToggle) return;
                            if (currentShell.contains(event.target)) return;
                            currentShell.classList.remove("open");
                            currentToggle.setAttribute("aria-expanded", "false");
                        });

                        document.addEventListener("keydown", function (event) {
                            if (event.key !== "Escape") return;
                            var currentShell = document.getElementById("admin-avatar-shell");
                            var currentToggle = document.getElementById("admin-avatar-toggle");
                            if (!currentShell || !currentToggle) return;
                            currentShell.classList.remove("open");
                            currentToggle.setAttribute("aria-expanded", "false");
                        });
                        window.__ahaAdminAvatarDocBound = true;
                    }
                }

                if (document.readyState === "loading") {
                    document.addEventListener("DOMContentLoaded", function () {
                        revealAdminAvatar();
                        bindAdminAvatarDropdown();
                    });
                } else {
                    revealAdminAvatar();
                    bindAdminAvatarDropdown();
                }

                window.addEventListener("pageshow", function () {
                    revealAdminAvatar();
                    bindAdminAvatarDropdown();
                });

                if (window.Sys && Sys.WebForms && Sys.WebForms.PageRequestManager) {
                    Sys.WebForms.PageRequestManager.getInstance().add_endRequest(function () {
                        revealAdminAvatar();
                        bindAdminAvatarDropdown();
                    });
                }
            })();
        </script>
        <asp:ContentPlaceHolder ID="foot" runat="server"></asp:ContentPlaceHolder>
        <%=ViewState["thongbao"] %>
    </form>
