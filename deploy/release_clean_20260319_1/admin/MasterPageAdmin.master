<body class="admin-shell admin-static admin-loading admin-avatar-nav-only">
    <script>
        (function () {
            function markAdminReady() {
                var body = document.body;
                if (!body) return;
                body.classList.remove("admin-loading");
                body.classList.add("admin-ready");
            }

            if (document.readyState === "loading") {
                document.addEventListener("DOMContentLoaded", markAdminReady);
            } else {
                markAdminReady();
            }

            window.addEventListener("pageshow", markAdminReady);
            window.setTimeout(markAdminReady, 1400);
        })();
    </script>
